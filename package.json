{
    "name": "rustybot-discord-bot",
    "version": "1.0.0",
    "description": "RustyBot - EVE Online Discord & Twitch Market Bot with real-time market data, manufacturing costs, and LP analysis",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "test": "node -c server.js && node -c twitch-bot.js && node -c twitch-utils.js && node -c token-manager.js && node -c gatecheck.js",
        "types:refresh": "node fetch_all_types.js",
        "setup": "npm install && node -c server.js",
        "docker:build": "docker build -t rustybot-discord-bot .",
        "docker:run": "docker run --env-file .env -p 8080:8080 rustybot-discord-bot",
        "health": "curl -f http://localhost:8080/health || exit 1",
        "deploy:check": "npm run test && echo '✅ Ready for deployment!'",
        "postinstall": "echo '✅ Dependencies installed. Configure .env file and run npm start'"
    },
    "keywords": [
        "discord",
        "twitch",
        "bot",
        "eve-online",
        "market",
        "rustybot",
        "gaming",
        "api",
        "real-time",
        "chat-bot",
        "multi-platform"
    ],
    "author": "",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nexis84/rustybot-discord-twitch.git"
    },
    "bugs": {
        "url": "https://github.com/nexis84/rustybot-discord-twitch/issues"
    },
    "homepage": "https://github.com/nexis84/rustybot-discord-twitch#readme",
    "engines": {
        "node": ">=16.0.0"
    },
    "dependencies": {
        "axios": "^1.11.0",
        "bottleneck": "^2.19.5",
        "discord.js": "14.25.1",
        "dotenv": "^17.2.2",
        "express": "^5.1.0",
        "irc": "^0.5.2",
        "node-fetch": "^3.3.2",
        "tmi.js": "^1.8.5",
        "web-streams-polyfill": "^4.2.0"
    }
}
